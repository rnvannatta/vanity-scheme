(import (vanity ephemeron) (vanity core))
(define (assert-equal? x y)
  (unless (equal? x y)
    (printf "~S is not equal to ~S~N" x y)
    (exit 1)))
(define (tp-key tp)
  (define-values (broken? key datum) (key-datum-pair-unpack tp))
  key)
(define (assert-ephemeron-equals eph broken? key datum)
  (define-values (eph-broken? eph-key eph-datum) (key-datum-pair-unpack eph))
  (unless
    (and (equal? broken? eph-broken?)
         (equal? key eph-key)
         (equal? datum eph-datum))
    (printf "ephemeron not equal #ephemeron(~A ~A ~A): ~A ~A ~A" eph-broken? eph-key eph-datum broken? key datum)
    (exit 1)))

(define tg (make-transport-guardian))
(define-values (tp0 tp1) (let ((tp (make-transport-pair tg (cons 1 1) (cons #t #t) (list 'x)))) (values tp (make-transport-pair tg (cons 2 2) 666))))
(##vcore.garbage-collect #f)
(define tp (let ((tp (make-transport-pair tg (cons 3 3) #f 555))) tp))
(##vcore.garbage-collect #f)
(define keys
  (list
    (let ((tp (transport-guardian-poll! tg))) (if tp (tp-key tp) 'nothing))
    (let ((tp (transport-guardian-poll! tg))) (if tp (tp-key tp) 'nothing))))
(assert-equal? (transport-pair-signaled? tp0) #t)
(assert-ephemeron-equals tp0 #f (cons 1 1) (cons #t #t))
(assert-equal? (transport-pair-luggage tp0) (list 'x))
(assert-equal? (transport-pair-signaled? tp1) #t)
(assert-ephemeron-equals tp1 #f (cons 2 2) #f)
(assert-equal? (transport-pair-luggage tp1) 666)
(assert-equal? (assoc 1 keys) (cons 1 1))
(assert-equal? (assoc 2 keys) (cons 2 2))
(assert-equal? (let ((tp (transport-guardian-poll! tg))) (if tp (tp-key tp) 'nothing)) (cons 3 3))
(assert-equal? (transport-guardian-poll! tg) #f)
(define eternal-tp (make-transport-pair tg 'x #t 999))
(define orphaned-tp  (make-transport-pair #f (cons #f #f) 'x 888))
(define eternal-orphaned-tp  (make-transport-pair #f 'y 'x 888))
(##vcore.garbage-collect #t)
(assert-equal? (transport-guardian-poll! tg) #f)
(assert-equal? (transport-pair-signaled? eternal-tp) #f)
(assert-equal? (transport-pair-signaled? orphaned-tp) #t)
(assert-equal? (transport-pair-signaled? eternal-orphaned-tp) #f)

(define tpx (make-transport-pair tg (cons 'x 'x) '?))
(##vcore.garbage-collect #f)
(define-values (key te) (let ((key (cons 'e 'e))) (values key (make-transport-ephemeron tg key key '!))))
(##vcore.garbage-collect #f)
(define tpz (make-transport-pair tg (cons 'z 'z) '?))
(##vcore.garbage-collect #f)
(assert-equal? (let ((tp (transport-guardian-poll! tg))) (if tp (tp-key tp) 'nothing)) (cons 'x 'x))
(assert-equal? (let ((tp (transport-guardian-poll! tg))) (if tp (tp-key tp) 'nothing)) (cons 'e 'e))
(assert-equal? (let ((tp (transport-guardian-poll! tg))) (if tp (tp-key tp) 'nothing)) (cons 'z 'z))
(assert-equal? (transport-pair-luggage te) '!)
(set! key #f)
(##vcore.garbage-collect #t)
(assert-ephemeron-equals te #t #f #f)
